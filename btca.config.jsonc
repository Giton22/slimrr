{
  "$schema": "https://btca.dev/btca.schema.json",
  "providerTimeoutMs": 300000,
  "resources": [
    {
      "type": "git",
      "name": "vue",
      "url": "https://github.com/vuejs/docs",
      "branch": "main",
      "searchPath": "src",
      "specialNotes": "Vue 3 documentation. Focus on guide and API reference content.",
    },
    {
      "type": "git",
      "name": "vueRouter",
      "url": "https://github.com/vuejs/router",
      "branch": "main",
      "searchPath": "packages/router",
      "specialNotes": "Vue Router source and docs.",
    },
    {
      "type": "git",
      "name": "pinia",
      "url": "https://github.com/vuejs/pinia",
      "branch": "v3",
      "searchPath": "packages/pinia",
      "specialNotes": "Pinia v3 state management for Vue.",
    },
    {
      "type": "git",
      "name": "tailwind",
      "url": "https://github.com/tailwindlabs/tailwindcss.com",
      "branch": "main",
      "searchPath": "src/docs",
      "specialNotes": "Tailwind CSS v4 documentation site.",
    },
    {
      "type": "git",
      "name": "vite",
      "url": "https://github.com/vitejs/vite",
      "branch": "main",
      "searchPath": "docs",
      "specialNotes": "Vite bundler documentation.",
    },
    {
      "type": "git",
      "name": "pocketbase",
      "url": "https://github.com/pocketbase/pocketbase",
      "branch": "master",
      "specialNotes": "PocketBase Go backend. Also see pocketbase/js-sdk for JS client.",
    },
    {
      "type": "git",
      "name": "rekaUi",
      "url": "https://github.com/unovue/reka-ui",
      "branch": "v2",
      "specialNotes": "Reka UI (formerly Radix Vue) - unstyled accessible Vue components.",
    },
    {
      "type": "git",
      "name": "vueuse",
      "url": "https://github.com/vueuse/vueuse",
      "branch": "main",
      "searchPath": "packages",
      "specialNotes": "VueUse composition utilities for Vue 3.",
    },
    {
      "type": "git",
      "name": "effect",
      "url": "https://github.com/Effect-TS/effect",
      "branch": "main",
      "specialNotes": "Effect-TS functional effect system. Monorepo with multiple packages.",
    },
  ],
  "model": "google/gemini-3-flash-preview",
  "provider": "openrouter",
}
